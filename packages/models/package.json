{
  "name": "@undefineds.co/models",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./ai-config": {
      "types": "./src/ai-config/index.ts",
      "default": "./dist/ai-config/index.js"
    },
    "./client": {
      "types": "./src/client/index.ts",
      "default": "./dist/client/index.js"
    },
    "./discovery": {
      "types": "./src/discovery/index.ts",
      "default": "./dist/discovery/index.js"
    },
    "./namespaces": {
      "types": "./src/namespaces.ts",
      "default": "./dist/namespaces.js"
    },
    "./profile": {
      "types": "./src/profile.ts",
      "default": "./dist/profile.js"
    },
    "./profile.repository": {
      "types": "./src/profile.repository.ts",
      "default": "./dist/profile.repository.js"
    },
    "./profile.schema": {
      "types": "./src/profile.schema.ts",
      "default": "./dist/profile.schema.js"
    },
    "./watch": {
      "types": "./src/watch/index.ts",
      "default": "./dist/watch/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "echo \"lint not configured\"",
    "pack:release": "node scripts/pack-release.mjs",
    "sync:discovery:vercel": "node --experimental-strip-types scripts/sync-discovery-vercel.ts",
    "test": "vitest",
    "test:pod": "dotenv -e ../../.env -- vitest run tests/pod.integration.test.ts"
  },
  "dependencies": {
    "@comunica/query-sparql-solid": "^4.0.2",
    "drizzle-orm": "^0.32.0",
    "@undefineds.co/drizzle-solid": "^0.3.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "dotenv-cli": "^7.3.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
