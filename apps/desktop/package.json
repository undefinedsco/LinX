{
  "name": "@linx/desktop",
  "version": "0.1.0",
  "description": "LinX Desktop Application",
  "main": "dist/apps/desktop/src/main.js",
  "scripts": {
    "build": "tsc && yarn run copy-assets",
    "test": "yarn build && node --test test/**/*.test.cjs",
    "copy-assets": "mkdir -p dist/pages && cp src/pages/*.html dist/pages/",
    "start": "electron .",
    "dev": "yarn workspace @linx/web dev & yarn run build && electron .",
    "link:xpod": "mkdir -p vendor && ln -sfn \"$(cd ../../.. && pwd)/xpod\" vendor/xpod",
    "build:xpod": "cd vendor/xpod && yarn install && yarn build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "build": {
    "appId": "co.undefineds.linx",
    "productName": "LinX",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "!node_modules/@undefineds.co/xpod/**/*"
    ],
    "extraResources": [
      {
        "from": "vendor/xpod",
        "to": "xpod",
        "filter": [
          "dist/**/*",
          "config/**/*",
          "templates/**/*",
          "static/**/*",
          "node_modules/**/*",
          "package.json"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Office"
    }
  }
}
